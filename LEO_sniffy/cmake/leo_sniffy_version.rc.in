#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @SNIFFY_VERSION_MAJOR@,@SNIFFY_VERSION_MINOR@,@SNIFFY_VERSION_PATCH@,0
 PRODUCTVERSION @SNIFFY_VERSION_MAJOR@,@SNIFFY_VERSION_MINOR@,@SNIFFY_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4"
        BEGIN
            VALUE "CompanyName", "Sniffy\0"
            VALUE "FileDescription", "Sniffy Desktop Application\0"
            VALUE "FileVersion", "@SNIFFY_DESKTOP_VERSION@\0"
            VALUE "InternalName", "LEO_sniffy\0"
            VALUE "OriginalFilename", "LEO_sniffy.exe\0"
            VALUE "ProductName", "Sniffy\0"
            VALUE "ProductVersion", "@SNIFFY_DESKTOP_VERSION@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1252
    END
END